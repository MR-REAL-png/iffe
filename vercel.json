{
  "version": 2,
  "routes": [
    {
      "src": "/api/parse-image",
      "dest": "/api/parse-image.js"
    },
    {
      "src": "/api/gemini",
      "dest": "/api/gemini.js"
    },
    {
      "src": "/api/sheets",
      "dest": "/api/sheets.js"
    },
    {
      "src": "/service-worker.js",
      "dest": "/service-worker.js",
      "headers": { "Content-Type": "application/javascript", "Service-Worker-Allowed": "/" }
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json",
      "headers": { "Content-Type": "application/manifest+json" }
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|ico|svg|webp|woff2|woff))",
      "dest": "/$1"
    },
    {
      "src": "/deploy-tool-iffe.html",
      "dest": "/deploy-tool-iffe.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
