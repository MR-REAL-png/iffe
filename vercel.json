{
  "version": 2,
  "functions": {
    "api/sheets.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/sheets.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|ico|svg|webp|woff2|woff))",
      "dest": "/$1"
    },
    {
      "src": "/deploy.html",
      "dest": "/deploy.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "SUPABASE_SERVICE_KEY": "@supabase_service_key"
  }
}
