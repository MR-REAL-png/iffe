{
  "version": 2,
  "routes": [
    {
      "src": "/api/parse-image",
      "dest": "/api/parse-image.js"
    },
    {
      "src": "/api/gemini",
      "dest": "/api/gemini.js"
    },
    {
      "src": "/api/sheets",
      "dest": "/api/sheets.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|ico|svg|webp|woff2|woff))",
      "dest": "/$1"
    },
    {
      "src": "/deploy-tool-iffe.html",
      "dest": "/deploy-tool-iffe.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
